# =============================================================================
# DealsScapper Environment Configuration
# =============================================================================
#
# For PRODUCTION deployment (docker-compose.prod.yml):
#   Only the variables in the "REQUIRED" section need to be set.
#   Everything else has sensible defaults in docker-compose.prod.yml.
#   Copy the required section to .env.prod and fill in your values.
#
# For LOCAL DEVELOPMENT:
#   Copy this entire file to .env and adjust values as needed.
#   Services run outside Docker, so localhost URLs are correct.

# =============================================================================
# REQUIRED — Must be set for any deployment
# =============================================================================

# Public Host — IP/hostname where services are accessible from a browser
# In production: your server IP (e.g., 192.168.1.200)
# In development: localhost (default)
PUBLIC_HOST=localhost

# Database Credentials (used by postgres container + derived into DATABASE_URL)
POSTGRES_USER=dealscrapper
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=dealscrapper

# Redis Password (required in production for --requirepass)
REDIS_PASSWORD=your-redis-password

# JWT Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# Email Verification (generate with: openssl rand -hex 32)
EMAIL_VERIFICATION_SECRET=your-email-verification-secret-change-this

# Gmail OAuth2 Email Service (required for production email delivery)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_USER_EMAIL=your-gmail-address@gmail.com

# =============================================================================
# OPTIONAL — Defaults provided by docker-compose.prod.yml
# =============================================================================
# Uncomment and modify only if you need to override the default value.

# --- Application ---
# NODE_ENV=development                    # production in docker-compose
# PORT=3001                               # API port
# APP_NAME=DealsScrapper
# APP_VERSION=1.0.0
# LOG_LEVEL=debug                         # info in production

# --- Database (local dev only, auto-derived in docker-compose) ---
# DATABASE_URL=postgresql://dealscrapper:your-postgres-password@localhost:5432/dealscrapper
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Redis ---
# REDIS_HOST=localhost                     # 'redis' in docker-compose
# REDIS_PORT=6379
# REDIS_DB=1

# --- Elasticsearch ---
# ELASTICSEARCH_NODE=http://localhost:9200 # http://elasticsearch:9200 in docker-compose

# --- JWT Expiry ---
# JWT_EXPIRES_IN=1h                       # 15m in production
# JWT_REFRESH_EXPIRES_IN=7d
# EMAIL_VERIFICATION_EXPIRES_IN=24h

# --- Security ---
# BCRYPT_ROUNDS=12
# RATE_LIMIT_WINDOW_MS=900000             # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_REQUESTS=5

# --- CORS (auto-derived from PUBLIC_HOST in docker-compose) ---
# CORS_ORIGIN=http://localhost:3000
# WEB_APP_URL=http://localhost:3000

# --- Scraping ---
# SCRAPING_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
# SCRAPING_TIMEOUT=30000
# SCRAPING_MAX_RETRIES=3
# RATE_LIMIT_DEALABS_REQUESTS_PER_HOUR=100
# RATE_LIMIT_DEALABS_CONCURRENT=2
# PAGES_PER_CATEGORY=5
# URL_OPTIMIZATION_ENABLED=true
# STARTUP_DISCOVER_CATEGORIES=false

# --- Puppeteer / Workers ---
# PUPPETEER_MAX_INSTANCES=3
# WORKER_MAX_CONCURRENT_JOBS=3
# WORKER_MAX_MEMORY_MB=2048

# --- Scheduler ---
# MAX_CONCURRENT_JOBS=3
# JOB_TIMEOUT=300000

# --- Service Ports (fixed in docker-compose, only needed for local dev) ---
# SCRAPER_PORT=3002
# SCHEDULER_PORT=3004
# NOTIFIER_PORT=3003

# --- Service URLs (local dev only, hardcoded in docker-compose) ---
# SCHEDULER_URL=http://localhost:3004
# NOTIFIER_URL=http://localhost:3003

# --- Email Branding ---
# FROM_EMAIL=noreply@dealscrapper.com
# FROM_NAME=DealsScrapper
# BRAND_PRIMARY_COLOR=#3B82F6
# SUPPORT_EMAIL=support@dealscrapper.com
# WEBSOCKET_NAMESPACE=/notifications

# --- Admin User Seeding (optional — skipped if not set) ---
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-strong-admin-password

# --- Email Provider Selection (required) ---
EMAIL_PROVIDER=mailhog          # 'gmail' | 'resend' | 'mailhog'

# --- Resend (if EMAIL_PROVIDER=resend) ---
# RESEND_API_KEY=re_your_api_key_here

# --- Email Dev/Test (MailHog) ---
# EMAIL_HOST=localhost
# EMAIL_PORT=1025

# --- Proxy (optional) ---
# PROXY_ENABLED=false
# PROXY_LIST=http://proxy1.com:8080,http://proxy2.com:8080
