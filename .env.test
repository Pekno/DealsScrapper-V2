# Application
NODE_ENV=test
NEXT_PUBLIC_APP_ENV=test
PORT=3001
APP_VERSION=1.0.0
APP_NAME=DealScrapper

# Database Configuration (Test)
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=dealscrapper_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Database URL (Test) - Host connection (services run on host, not in Docker)
DATABASE_URL=postgresql://test:test@localhost:5433/dealscrapper_test

# Redis (Test)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

# JWT Authentication (Test - weaker for faster tests)
JWT_SECRET=test-jwt-secret-not-for-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-not-for-production
JWT_REFRESH_EXPIRES_IN=24h

# Email Verification (Test)
EMAIL_VERIFICATION_SECRET=test-email-verification-secret
EMAIL_VERIFICATION_EXPIRES_IN=1h

# Security Configuration (Test - less strict for faster tests)
BCRYPT_ROUNDS=4
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
AUTH_RATE_LIMIT_MAX_REQUESTS=50

# CORS Configuration (Test)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Elasticsearch (Test)
ELASTICSEARCH_PORT=9201
ELASTICSEARCH_NODE=http://localhost:9201

# Scraping Configuration (Test - faster/less strict)
SCRAPING_USER_AGENT="Mozilla/5.0 (Test Bot)"
SCRAPING_TIMEOUT=5000
SCRAPING_MAX_RETRIES=1
PUPPETEER_MAX_INSTANCES=2
WORKER_ID=worker-test-001
WORKER_ENDPOINT=http://localhost:3002
WORKER_MAX_CONCURRENT_JOBS=2
WORKER_MAX_MEMORY_MB=1024
HOSTNAME=worker-test
PAGES_PER_CATEGORY=2
SCHEDULER_URL=http://localhost:3004
NOTIFIER_URL=http://localhost:3003

# Rate Limiting (Test - more permissive)
RATE_LIMIT_DEALABS_REQUESTS_PER_HOUR=1000
RATE_LIMIT_DEALABS_CONCURRENT=5

# Proxy Configuration (Test - disabled)
PROXY_ENABLED=false
PROXY_LIST=

# Notifier Service Configuration (Test)
WEB_APP_URL=http://localhost:3000
WEBSOCKET_NAMESPACE=/notifications

# Email Configuration (Test - MailHog SMTP on localhost)
EMAIL_PROVIDER=mailhog
EMAIL_HOST=localhost
EMAIL_PORT=1025
FROM_EMAIL=test@dealscrapper.test
FROM_NAME="DealScrapper Test"
BRAND_PRIMARY_COLOR="#3B82F6"
SUPPORT_EMAIL=support@dealscrapper.test

# Logging (Test - debug level for detailed test debugging)
LOG_LEVEL=debug

# Service Ports (Test - matching Cypress expectations)
SCRAPER_PORT=3002
SCHEDULER_PORT=3004
NOTIFIER_PORT=3003

# Scaling Configuration (Test - single instance)
SCRAPER_REPLICAS=1

# URL Filter Optimization (Test)
URL_OPTIMIZATION_ENABLED=true
# Admin User Seeding
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminP@ssw0rd

PASSWORD_RESET_SECRET=test-password-reset-secret
PASSWORD_RESET_EXPIRES_IN=30m
