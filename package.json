{
  "name": "dealscrapper",
  "version": "0.0.1",
  "private": true,
  "description": "Modern deal aggregation platform with intelligent filtering",
  "author": "Dealscrapper Team",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cli": "tsx packages/cli/src/index.ts",
    "dev": "pnpm dev:setup && turbo run dev --concurrency 12",
    "dev:setup": "docker compose -f docker-compose.dev.yml up -d --build && cd packages/database && dotenv -e ../../.env prisma db push",
    "dev:api": "turbo run dev --filter=@dealscrapper/api",
    "dev:scraper": "turbo run dev --filter=@dealscrapper/scraper",
    "dev:notifier": "turbo run dev --filter=@dealscrapper/notifier",
    "dev:scheduler": "turbo run dev --filter=@dealscrapper/scheduler",
    "dev:web": "turbo run dev --filter=@dealscrapper/web",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "type-check": "turbo run type-check",
    "test:api:unit": "turbo run test:unit --filter=@dealscrapper/api --output-logs=full",
    "test:api:e2e": "turbo run test:e2e --filter=@dealscrapper/api --output-logs=full",
    "test:scraper:unit": "turbo run test:unit --filter=@dealscrapper/scraper --output-logs=full",
    "test:scraper:e2e": "turbo run test:e2e --filter=@dealscrapper/scraper --output-logs=full",
    "test:notifier:unit": "turbo run test:unit --filter=@dealscrapper/notifier --output-logs=full",
    "test:notifier:e2e": "turbo run test:e2e --filter=@dealscrapper/notifier --output-logs=full",
    "test:scheduler:unit": "turbo run test:unit --filter=@dealscrapper/scheduler --output-logs=full",
    "test:scheduler:e2e": "turbo run test:e2e --filter=@dealscrapper/scheduler --output-logs=full",
    "test:e2e": "cypress run --browser electron --headless",
    "test:e2e:open": "cypress open",
    "test:e2e:headed": "cypress run --browser electron --headed",
    "test:e2e:chrome": "cypress run --browser chrome --headless",
    "test:e2e:auth": "cypress run --spec 'test/e2e/auth/**/*.cy.ts'",
    "test:e2e:filters": "cypress run --spec 'test/e2e/filters/**/*.cy.ts'",
    "test:e2e:basic": "cypress run --spec 'test/e2e/basic/**/*.cy.ts'",
    "test:e2e:smoke": "cypress run --env grepTags=@smoke",
    "clean": "turbo run clean",
    "clean:logs": "shx rm -rf apps/*/logs/*.log apps/*/.turbo/*.log",
    "db:generate": "turbo run db:generate --filter=@dealscrapper/database",
    "db:migrate": "turbo run db:migrate --filter=@dealscrapper/database",
    "db:studio": "turbo run db:studio --filter=@dealscrapper/database",
    "db:seed": "turbo run db:seed --filter=@dealscrapper/database",
    "db:reset": "turbo run db:reset --filter=@dealscrapper/database",
    "start": "turbo run start --parallel",
    "start:api": "turbo run start --filter=@dealscrapper/api",
    "start:scraper": "turbo run start --filter=@dealscrapper/scraper",
    "start:notifier": "turbo run start --filter=@dealscrapper/notifier",
    "start:scheduler": "turbo run start --filter=@dealscrapper/scheduler",
    "start:web": "turbo run start --filter=@dealscrapper/web",
    "verify": "node scripts/verify-commands.js"
  },
  "devDependencies": {
    "@cypress/grep": "^4.1.1",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/common": "^11.1.3",
    "@nestjs/testing": "^11.1.3",
    "@nx/webpack": "^21.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cypress": "^15.7.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^30.0.3",
    "prettier": "^3.1.1",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "deals",
    "scraping",
    "aggregation",
    "notifications",
    "typescript",
    "nestjs",
    "vite",
    "prisma"
  ],
  "dependencies": {
    "dompurify": "^3.2.6",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "redis": "^5.5.6",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "uuid": "^11.1.0"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "inject-workspace-packages": true
  }
}
