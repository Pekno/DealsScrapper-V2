{
  "name": "@dealscrapper/scraper",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_OPTIONS='--max-old-space-size=4096' nest start",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' dotenv -e ../../.env -- nest start --watch --preserveWatchOutput",
    "start:debug": "NODE_OPTIONS='--max-old-space-size=4096' nest start --debug --watch",
    "start:prod": "NODE_OPTIONS='--max-old-space-size=4096' node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "clean": "shx rm -rf dist tsconfig.build.tsbuildinfo",
    "test:unit": "dotenv -e ../../.env.test -- jest --forceExit --detectOpenHandles --verbose",
    "test:e2e": "dotenv -e ../../.env.test -- jest --config jest-e2e.config.mjs --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "@dealscrapper/database": "workspace:*",
    "@dealscrapper/shared": "workspace:*",
    "@dealscrapper/shared-config": "workspace:*",
    "@dealscrapper/shared-health": "workspace:*",
    "@dealscrapper/shared-logging": "workspace:*",
    "@dealscrapper/shared-repository": "workspace:*",
    "@dealscrapper/shared-types": "workspace:*",
    "@elastic/elasticsearch": "^9.0.3",
    "@nestjs/bull": "^11.0.2",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/elasticsearch": "^11.1.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "axios": "^1.7.9",
    "bull": "^4.16.5",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "puppeteer": "^23.11.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rxjs": "^7.8.2",
    "user-agents": "^1.1.344",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "domhandler": "^5.0.3",
    "jest": "^30.0.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
