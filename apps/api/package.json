{
  "name": "@dealscrapper/api",
  "version": "0.0.1",
  "description": "Real-time notification service with WebSocket support",
  "author": "Dealscrapper Team",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "dotenv -e ../../.env -- nest start --watch --preserveWatchOutput",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "clean": "shx rm -rf dist tsconfig.build.tsbuildinfo",
    "test:unit": "dotenv -e ../../.env.test -- jest --forceExit --detectOpenHandles --verbose",
    "test:e2e": "dotenv -e ../../.env.test -- jest --config jest-e2e.config.mjs --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "@dealscrapper/database": "workspace:*",
    "@dealscrapper/shared": "workspace:*",
    "@dealscrapper/shared-config": "workspace:*",
    "@dealscrapper/shared-health": "workspace:*",
    "@dealscrapper/shared-logging": "workspace:*",
    "@dealscrapper/shared-repository": "workspace:*",
    "@dealscrapper/shared-types": "workspace:*",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bull": "^11.0.2",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/elasticsearch": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^5.1.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "rxjs": "^7.8.2",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/testing": "^11.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.10",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "jest": "^30.0.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
