{
  "name": "@dealscrapper/notifier",
  "version": "0.0.1",
  "description": "Real-time notification service with WebSocket support",
  "author": "Dealscrapper Team",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "dotenv -e ../../.env -- nest start --watch --preserveWatchOutput",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "clean": "shx rm -rf dist tsconfig.build.tsbuildinfo",
    "test:unit": "dotenv -e ../../.env.test -- jest --forceExit --detectOpenHandles --verbose",
    "test:e2e": "dotenv -e ../../.env.test -- jest --config jest-e2e.config.mjs --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "@dealscrapper/database": "workspace:*",
    "@dealscrapper/shared-config": "workspace:*",
    "@dealscrapper/shared-health": "workspace:*",
    "@dealscrapper/shared-logging": "workspace:*",
    "@dealscrapper/shared-repository": "workspace:*",
    "@dealscrapper/shared-types": "workspace:*",
    "@nestjs/bull": "^11.0.2",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.3",
    "bull": "^4.16.5",
    "dompurify": "^3.2.6",
    "googleapis": "^154.0.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.6.1",
    "jsdom": "^26.1.0",
    "mjml": "^4.15.3",
    "nodemailer": "^7.0.4",
    "resend": "^6.10.0",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.3",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/mjml": "^4.7.4",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^6.4.17",
    "dotenv": "^16.4.5",
    "jest": "^30.0.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
